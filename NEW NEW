local function handleSlider(btn, track, label, fill, min, max, callback)
    local dragging = false
    local function update()
        local pos = math.clamp((uis:GetMouseLocation().X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        local val = math.floor(min + (max - min) * pos)
        fill.Size = UDim2.new(pos, 0, 1, 0)
        btn.Position = UDim2.new(pos, -6, 0.5, -6)
        label.Text = label.Text:split(":")[1] .. ": " .. val
        callback(val)
    end
    btn.MouseButton1Down:Connect(function() dragging = true end)
    uis.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
    runService.RenderStepped:Connect(function() if dragging then update() end end)
end

local function createBtn(txt, parent, callback)
    local b = Instance.new("TextButton")
