local function toggleFly()
    flying = not flying; updateBtnUI(funcs["fBtnObj"], flying)
    if flying then task.spawn(function() 
        local char = player.Character; bv = Instance.new("BodyVelocity", char.HumanoidRootPart); bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
        bg = Instance.new("BodyGyro", char.HumanoidRootPart); bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge); char.Humanoid.PlatformStand = true
        while flying and char.Parent do 
            local cam = workspace.CurrentCamera; local dir = Vector3.new(0,0,0)
            if uis:IsKeyDown(Enum.KeyCode.W) then dir += cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.S) then dir -= cam.CFrame.LookVector end
            if uis:IsKeyDown(Enum.KeyCode.A) then dir -= cam.CFrame.RightVector end
            if uis:IsKeyDown(Enum.KeyCode.D) then dir += cam.CFrame.RightVector end
            bv.Velocity = dir.Unit * flySpeed; if dir.Magnitude == 0 then bv.Velocity = Vector3.new(0,0,0) end
            bg.CFrame = cam.CFrame; runService.RenderStepped:Wait() 
        end
        if bv then bv:Destroy() end if bg then bg:Destroy() end char.Humanoid.PlatformStand = false 
    end) end
end

