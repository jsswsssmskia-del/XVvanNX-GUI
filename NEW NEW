    bindText.Size = UDim2.new(0, 50, 1, 0); bindText.Position = UDim2.new(1, -55, 0, 0)
    bindText.BackgroundTransparency = 1; bindText.Text = ""; bindText.TextColor3 = Color3.fromRGB(150, 150, 150)
    bindText.Font = secondaryFont; bindText.TextSize = 9; bindText.TextXAlignment = Enum.TextXAlignment.Right
    bindText.Parent = b

    funcs[txt] = callback

    b.MouseButton1Click:Connect(function()
        callback()
    end)

    b.MouseButton2Click:Connect(function()
        contextMenu.Position = UDim2.new(0, uis:GetMouseLocation().X, 0, uis:GetMouseLocation().Y - 36)
        contextMenu.Visible = true
        bindingButton = {Btn = b, Name = txt}
    end)

    table.insert(activeButtons, b)
    return b
end

uis.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    
    if input.UserInputType == Enum.UserInputType.MouseButton1 and contextMenu.Visible then
        task.wait(0.1)
        contextMenu.Visible = false
    end
    
    if bindingButton and input.UserInputType == Enum.UserInputType.Keyboard then
        local key = input.KeyCode.Name
        binds[key] = bindingButton.Name -- Сохраняем имя функции за клавишей
        bindingButton.Btn:FindFirstChild("BindDisplay").Text = "["..key.."]"
        bindingButton = nil
        contextMenu.Visible = false
    elseif input.UserInputType == Enum.UserInputType.Keyboard then
        local funcName = binds[input.KeyCode.Name]
        if funcName and funcs[funcName] then
            funcs[funcName]() -- Вызываем напрямую
        end
    end
end)

