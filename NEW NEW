    b.Text = txt..": OFF"; b.TextColor3 = Color3.new(1, 1, 1); b.Font = secondaryFont; b.TextSize = 10
    b.Parent = parent; Instance.new("UICorner", b).CornerRadius = UDim.new(0, 6)
    
    local bindText = Instance.new("TextLabel")
